<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#ECEFF1">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RoboAGV"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Mode Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#1976D2"
        app:tabTextColor="#80FFFFFF"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#FFFFFF"
        app:tabIndicatorHeight="3dp" />

    <!-- Camera Preview (always visible) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Robot View (navigate mode only) -->
    <com.roboagv.RobotView
        android:id="@+id/robotView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#FFFFFF"
        android:visibility="gone" />

    <!-- Status text -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#E3F2FD"
        android:text="Ready"
        android:textColor="#0D47A1"
        android:textSize="14sp" />

    <!-- Navigate controls -->
    <LinearLayout
        android:id="@+id/navigatePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoice"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Hold to Speak"
            android:textSize="16sp"
            android:paddingHorizontal="32dp"
            app:cornerRadius="28dp"
            app:icon="@android:drawable/ic_btn_speak_now" />
    </LinearLayout>

    <!-- Record Room controls -->
    <LinearLayout
        android:id="@+id/recordPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Capture"
            android:textSize="14sp"
            app:backgroundTint="#2E7D32"
            app:icon="@android:drawable/ic_menu_camera" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveRoom"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Save Room"
            android:textSize="14sp"
            app:backgroundTint="#E65100"
            app:icon="@android:drawable/ic_menu_save" />

        <TextView
            android:id="@+id/imageCountText"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:gravity="center"
            android:paddingStart="12dp"
            android:textSize="13sp"
            android:textColor="#555555"
            android:text="0 photos" />
    </LinearLayout>

</LinearLayout>
